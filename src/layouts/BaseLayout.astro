---
import '../styles/global.css';

type Props = {
  title: string;
  description?: string;
};

const { title, description = '个人面试复盘与知识库' } = Astro.props;

const { BASE_URL } = import.meta.env;
const navItems = [
  { href: BASE_URL, label: '总览' },
  { href: `${BASE_URL}/interviews/`, label: '面试' },
  { href: `${BASE_URL}/companies/`, label: '公司' },
  { href: `${BASE_URL}/questions/`, label: '问题' },
  { href: `${BASE_URL}/knowledge/`, label: '知识库' },
  { href: `${BASE_URL}/search/`, label: '搜索' }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Interview Tracker</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={import.meta.env.BASE_URL}>
        <span class="brand-mark">IT</span>
        <span>
          <strong>Interview Tracker</strong>
          <small>面试复盘知识库</small>
        </span>
      </a>
      <nav aria-label="主导航">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
